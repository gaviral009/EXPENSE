#  AI INSIGHT POPUP — ask_ai_insight
#  Shows a summary messagebox with portfolio breakdown.
#  (A real version would call an AI API — this is a clean local version.)
# ══════════════════════════════════════════════════════════════════════════════
def ask_ai_insight():
    if len(holdings_list) == 0:
        messagebox.showinfo("AI Insight",
                            "Add holdings first to get portfolio insights.")
        return

    total_val = sum(h["value"]    for h in holdings_list)   # Sum all current values.
    total_inv = sum(h["invested"] for h in holdings_list)   # Sum all invested amounts.

    lines = ["Portfolio Analysis\n"]
    lines.append("Total Invested : " + format_inr(total_inv))
    lines.append("Current Value  : " + format_inr(total_val))

    gain = total_val - total_inv
    gain_pct = (gain / total_inv * 100) if total_inv > 0 else 0.0
    sign = "+" if gain >= 0 else ""
    lines.append("Overall P&L    : " + sign + format_inr(gain) +
                 " (" + sign + str(round(gain_pct, 1)) + "%)\n")

    lines.append("Holdings Breakdown:")
    for h in holdings_list:
        gl  = h["value"] - h["invested"]
        p   = (gl / h["invested"] * 100) if h["invested"] > 0 else 0.0
        s   = "+" if p >= 0 else ""
        lines.append("  " + h["name"] + " : " + format_inr(h["value"]) +
                     " (" + s + str(round(p, 1)) + "%)")

    # Join all lines with newline characters and show as a popup box.
    messagebox.showinfo("AI Wealth Insight", "\n".join(lines))


