# ══════════════════════════════════════════════════════════════════════════════
#  HELPER FUNCTION 1 — format_inr
#  Turns a plain number like 1234567 into the Indian number system: ₹12,34,567
#  India groups digits as: ...XX,XX,XX,XXX  (last 3, then pairs from right)
# ══════════════════════════════════════════════════════════════════════════════
def format_inr(amount):
    # Round to the nearest whole rupee and convert to int so we have no decimals.
    amount = int(round(amount))

    # We work with the absolute value (ignore minus sign for now) as a string.
    s = str(abs(amount))

    if len(s) <= 3:
        # If the number has 3 or fewer digits (e.g. 500), no commas needed.
        result = s
    else:
        # Split the string: last 3 digits go in one group, the rest get paired.
        last3 = s[-3:]   # e.g. for "1234567"  →  last3 = "567"
        rest  = s[:-3]   # e.g.                →  rest  = "1234"

        groups = []                    # We'll collect the pairs here.
        while len(rest) > 2:           # As long as there are more than 2 digits left...
            groups.append(rest[-2:])   # ...grab the last 2 digits and save them.
            rest = rest[:-2]           # Chop those 2 digits off.
        if rest:                       # Whatever tiny piece is left (1 or 2 digits)...
            groups.append(rest)        # ...add it too.

        groups.reverse()               # We collected pairs right-to-left, so flip the list.
        result = ",".join(groups) + "," + last3  # Stitch everything together with commas.

    # Stick the ₹ symbol on the front.  If the original was negative, add a minus sign too.
    if amount < 0:
        return "-₹" + result
    return "₹" + result


# ══════════════════════════════════════════════════════════════════════════════
#  HELPER FUNCTION 2 — get_pct_color
#  Decides whether to use GREEN (profit) or RED (loss) based on a number.
# ══════════════════════════════════════════════════════════════════════════════
def get_pct_color(val):
    # If the value is zero or positive (we made money or broke even) → green.
    # Otherwise (we lost money) → red.
    if val >= 0:
        return GREEN
    return RED


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN REFRESH FUNCTION — recalculate_and_refresh
#  Called every time the user adds a new investment.
#  It re-adds up everything and updates every label on screen.
# ══════════════════════════════════════════════════════════════════════════════
def recalculate_and_refresh():
    # ── Step 1: Add up all the money ──────────────────────────────────────────
    total_val = 0   # Will hold current market value of all investments.
    total_inv = 0   # Will hold the total amount the user originally put in.

    for h in holdings_list:        # Loop through every holding in our notebook.
        total_val += h["value"]    # Add its current value to the running total.
        total_inv += h["invested"] # Add its invested amount to the running total.

    # ── Step 2: Update the "Total Portfolio Value" big number on screen ───────
    label_total_val.configure(text=format_inr(total_val))  # e.g. "₹12,34,567"
    label_invested_val.configure(text=format_inr(total_inv))

    # ── Step 3: Calculate Year-To-Date (YTD) percentage gain/loss ─────────────
    gain_loss = total_val - total_inv   # How much money did we make or lose overall?

    if total_inv > 0:
        # Percentage = (profit / original investment) × 100
        ytd_pct = (gain_loss / total_inv) * 100
    else:
        ytd_pct = 0.0   # Avoid dividing by zero if nothing invested yet.

    sign = "+" if ytd_pct >= 0 else ""   # Add a "+" sign for positive numbers.
    label_ytd.configure(
        text=sign + str(round(ytd_pct, 1)) + "% YTD",
        text_color=get_pct_color(ytd_pct)   # Green or red depending on profit/loss.
    )

    # ── Step 4: Simulate "Today's" return ────────────────────────────────────
    # We don't have live data, so we pretend today's move is 32% of total gain.
    # This is just a placeholder so the UI looks realistic.
    today_gl  = gain_loss * 0.32
    today_pct = (today_gl / total_val * 100) if total_val > 0 else 0.0

    sign2 = "+" if today_pct >= 0 else ""
    label_today_change.configure(
        text=sign2 + str(round(today_pct, 2)) + "% today",
        text_color=get_pct_color(today_pct)
    )
    label_today_ret.configure(
        text=format_inr(today_gl),
        text_color=get_pct_color(today_pct)
    )
    sign3 = "+" if today_pct >= 0 else ""
    label_today_pct.configure(
        text=sign3 + str(round(today_pct, 2)) + "%",
        text_color=get_pct_color(today_pct)
    )

    # ── Step 5: Update the AI insight text on the right panel ─────────────────
    if len(holdings_list) > 0:
        # Sort holdings by current value, biggest first.
        sorted_h  = sorted(holdings_list, key=lambda x: x["value"], reverse=True)
        top_names = [sorted_h[0]["name"]]          # Always include the #1 holding.
        if len(sorted_h) > 1:
            top_names.append(sorted_h[1]["name"])  # If there's a #2, include it too.
        top_str = " and ".join(top_names)           # e.g. "Reliance and Infosys"
        label_ai_text.configure(
            text="Your portfolio is led by " + top_str +
                 ". Consider rebalancing if any single holding exceeds 40% of total value."
        )
    else:
        label_ai_text.configure(
            text="Add holdings to get personalized portfolio insights and recommendations."
        )

    # ── Step 6: Redraw the chart and rebuild the holdings grid ────────────────
    draw_mini_chart(total_val, total_inv)  # Redraws the performance graph.
    rebuild_holdings_grid()                # Redraws the holding cards below.


# ══════════════════════════════════════════════════════════════════════════════
#  HELPER FUNCTION 3 — lerp_color
#  "lerp" = Linear Interpolation = smoothly mixing two colours.
#  Imagine sliding a knob between RED and GREEN — midway gives you YELLOW.
#  t=0.0  →  returns c1 exactly.
#  t=0.5  →  returns the colour halfway between c1 and c2.
#  t=1.0  →  returns c2 exactly.
# ══════════════════════════════════════════════════════════════════════════════
def lerp_color(c1, c2, t):
    # Convert hex string "#rrggbb" into three separate numbers (red, green, blue).
    # int(c1[1:3], 16) means: take characters 1-2 of the string and read them as
    # a base-16 (hexadecimal) number.  e.g. "ff" → 255.
    r1, g1, b1 = int(c1[1:3], 16), int(c1[3:5], 16), int(c1[5:7], 16)
    r2, g2, b2 = int(c2[1:3], 16), int(c2[3:5], 16), int(c2[5:7], 16)

    # Mix each channel: start + (end - start) × how_far_along
    r = int(r1 + (r2 - r1) * t)
    g = int(g1 + (g2 - g1) * t)
    b = int(b1 + (b2 - b1) * t)

    # Pack the three numbers back into a "#rrggbb" string.
    # :02x means "write as 2-digit hex, pad with zero if needed".
    return f"#{r:02x}{g:02x}{b:02x}"


# ══════════════════════════════════════════════════════════════════════════════
#  CHART DRAWING FUNCTION — draw_mini_chart   ✅ NOW WITH REAL DATE/TIME LABELS
#  Draws the animated performance line chart on the canvas widget.
#
#  Think of the canvas like a blank piece of paper.
#  We:  1. Draw faint horizontal grid lines (like notebook lines).
#       2. Calculate 8 data points (Jan → Now) on a smooth curve.
#       3. Fill the area under the curve with a pretty gradient.
#       4. Draw the bright teal line on top.
#       5. Put date labels along the bottom.  ← NEW: real calendar dates!
# ══════════════════════════════════════════════════════════════════════════════
def draw_mini_chart(total_val, total_inv):
    import calendar

    chart_canvas.delete("all")

    w = chart_canvas.winfo_width()
    h = chart_canvas.winfo_height()
    if w < 10 or h < 10:
        chart_canvas.after(100, lambda: draw_mini_chart(total_val, total_inv))
        return

    # ── Padding ───────────────────────────────────────────────────────────────
    pad_left   = 56   # space on left for ₹ axis labels
    pad_right  = 16
    pad_top    = 14
    pad_bottom = 46   # extra room for two-line date+time labels at the bottom

    chart_w = w - pad_left - pad_right
    chart_h = h - pad_top  - pad_bottom

    # ── EMPTY STATE: no investments added yet ─────────────────────────────────
    # If nobody has pressed "+ New Investment" yet, portfolio_history is empty.
    # Draw a flat dashed line at mid-height with a friendly label.
    if len(portfolio_history) == 0:
        mid_y = pad_top + chart_h // 2
        # Dashed line: draw short segments manually (tkinter dash support is unreliable)
        seg = 8
        x = pad_left
        while x < w - pad_right:
            chart_canvas.create_line(x, mid_y, min(x + seg, w - pad_right), mid_y,
                                     fill=BORDER, width=1)
            x += seg * 2
        chart_canvas.create_text(w // 2, mid_y - 14,
                                  text="Add an investment to see your chart",
                                  fill=MUTED, font=("Segoe UI", 9), anchor="s")
        return

    # ── SINGLE POINT: exactly one investment added ────────────────────────────
    # We only have one dot in history — can't draw a line yet.
    # Show the single point with its timestamp and a label.
    if len(portfolio_history) == 1:
        ts, val, inv = portfolio_history[0]
        dot_x = pad_left + chart_w // 2
        dot_y = pad_top  + chart_h // 2

        # Horizontal reference line (invested amount baseline)
        chart_canvas.create_line(pad_left, dot_y, w - pad_right, dot_y,
                                  fill=BORDER, width=1)

        # The single data point dot
        chart_canvas.create_oval(dot_x - 5, dot_y - 5, dot_x + 5, dot_y + 5,
                                  fill=ACCENT, outline=CARD)

        # Value label above the dot
        chart_canvas.create_text(dot_x, dot_y - 10,
                                  text=format_inr(val),
                                  fill=TEXT, font=("Segoe UI", 9, "bold"), anchor="s")

        # Timestamp label below the dot  (e.g.  "30 Apr 2026  14:35")
        time_str = ts.strftime("%d %b %Y  %H:%M")
        chart_canvas.create_text(dot_x, dot_y + 10,
                                  text=time_str,
                                  fill=ACCENT, font=("Segoe UI", 8), anchor="n")
        return

    # ── MULTIPLE POINTS: build the real chart from portfolio_history ──────────
    # Each entry in portfolio_history is (datetime, total_value, total_invested).
    # We use these directly — no fake interpolation at all.

    y_values = [entry[1] for entry in portfolio_history]   # list of portfolio values
    timestamps = [entry[0] for entry in portfolio_history] # list of datetimes

    mn  = min(y_values)
    mx  = max(y_values)
    rng = mx - mn if mx != mn else 1   # avoid division by zero if all values equal

    # Give a little visual breathing room so the line doesn't hug the very top/bottom
    mn_display = mn * 0.97
    mx_display = mx * 1.03
    rng_display = mx_display - mn_display

    num_points = len(y_values)

    # ── Y-axis grid lines and ₹ labels ────────────────────────────────────────
    num_grid = 4
    for i in range(num_grid + 1):
        grid_y   = pad_top + (chart_h / num_grid) * i
        raw_val  = mx_display - (rng_display / num_grid) * i

        chart_canvas.create_line(pad_left, grid_y, w - pad_right, grid_y,
                                  fill="#1e2d3d", width=1)

        tick = ("₹" + str(int(raw_val // 1000)) + "k") if raw_val >= 100_000 else ("₹" + str(int(raw_val)))
        chart_canvas.create_text(pad_left - 4, grid_y, text=tick,
                                  anchor="e", fill=MUTED, font=("Segoe UI", 8))

    # ── Convert values → pixel coordinates ───────────────────────────────────
    coords = []
    for i, val in enumerate(y_values):
        x = pad_left + (i / (num_points - 1)) * chart_w
        y = pad_top  + chart_h - ((val - mn_display) / rng_display) * chart_h
        coords.append((x, y))

    # ── Gradient fill under the line ─────────────────────────────────────────
    bottom_y = pad_top + chart_h

    fill_pts = list(coords)
    fill_pts.append((coords[-1][0], bottom_y))
    fill_pts.append((coords[0][0],  bottom_y))
    flat = []
    for pt in fill_pts:
        flat.extend(pt)

    chart_canvas.create_polygon(flat, fill="#004530", outline="")

    num_fill_steps = 36
    for step in range(num_fill_steps):
        frac  = step / num_fill_steps
        color = lerp_color("#005a3c", CARD, frac)
        strip_y_start = int(pad_top + chart_h * frac)
        strip_y_end   = strip_y_start + max(1, int(chart_h / num_fill_steps))
        chart_canvas.create_rectangle(coords[0][0], strip_y_start,
                                       coords[-1][0], strip_y_end,
                                       fill=color, outline="")

    chart_canvas.create_polygon(flat, fill="#004530", outline="")

    # ── Draw the line between real data points ────────────────────────────────
    for i in range(len(coords) - 1):
        x1, y1 = coords[i]
        x2, y2 = coords[i + 1]
        chart_canvas.create_line(x1, y1, x2, y2, fill=ACCENT, width=2, smooth=True)

    # ── Dot on every real data point ──────────────────────────────────────────
    for i, (cx, cy) in enumerate(coords):
        is_last = (i == len(coords) - 1)
        r = 5 if is_last else 3
        chart_canvas.create_oval(cx - r, cy - r, cx + r, cy + r,
                                  fill=ACCENT, outline=CARD)

    # ── X-axis date/time labels — ONE label per real data point ───────────────
    # Each label is the actual datetime the user pressed "+ New Investment".
    # Format:  "30 Apr"  on the first line,  "14:35"  on the second line.
    # The LAST label also gets a "Now" prefix and is shown in bright teal.
    for i, ts in enumerate(timestamps):
        cx = coords[i][0]
        date_line = ts.strftime("%d %b")     # e.g. "30 Apr"
        time_line = ts.strftime("%H:%M")     # e.g. "14:35"
        label_text = date_line + "\n" + time_line

        is_last = (i == len(timestamps) - 1)
        colour   = ACCENT if is_last else MUTED
        weight   = "bold"  if is_last else "normal"

        chart_canvas.create_text(cx, bottom_y + 5,
                                  text=label_text,
                                  fill=colour,
                                  font=("Segoe UI", 7, weight),
                                  anchor="n",
                                  justify="center")



# ══════════════════════════════════════════════════════════════════════════════
#  HOLDINGS GRID BUILDER — rebuild_holdings_grid
#  Clears and redraws the card grid showing each investment.
# ══════════════════════════════════════════════════════════════════════════════
def rebuild_holdings_grid():
    # Destroy every existing widget inside the holdings_frame.
    # This is like erasing the whiteboard before writing fresh info.
    for widget in holdings_frame.winfo_children():
        widget.destroy()

    # If the user hasn't added anything yet, show a friendly empty state message.
    if len(holdings_list) == 0:
        empty_lbl = ctk.CTkLabel(
            holdings_frame,
            text="No holdings yet  ·  click + New Investment",
            font=("Segoe UI", 11),
            text_color=MUTED
        )
        empty_lbl.grid(row=0, column=0, columnspan=3, pady=30)
        return

    # Layout: 3 cards per row.  col tracks the current column (0, 1, 2).
    col = 0
    row = 0

    for h in holdings_list:
        # Calculate profit/loss for this individual holding.
        gl = h["value"] - h["invested"]
        pct = (gl / h["invested"] * 100) if h["invested"] > 0 else 0.0

        # ── Build the card frame ──────────────────────────────────────────────
        card = ctk.CTkFrame(
            holdings_frame,
            fg_color=CARD,        # Card background colour.
            corner_radius=12,     # Rounded corners.
            border_width=1,
            border_color=BORDER
        )
        card.grid(row=row, column=col, padx=5, pady=5, sticky="nsew")
        card.columnconfigure(1, weight=1)   # Middle column stretches to fill space.

        # ── Coloured icon square (top-left of card) ───────────────────────────
        # Think of it as a little avatar badge for the asset.
        icon_frame = ctk.CTkFrame(
            card,
            fg_color=h["color"],   # e.g. blue, orange, teal — set when user added it.
            width=42, height=42,
            corner_radius=10
        )
        icon_frame.grid(row=0, column=0, rowspan=2, padx=(12, 8), pady=12)
        icon_frame.grid_propagate(False)   # grid_propagate(False) = don't resize to children.

        icon_lbl = ctk.CTkLabel(
            icon_frame,
            text=h["letter"],              # First letter of the ticker, e.g. "R" for Reliance.
            font=("Segoe UI", 16, "bold"),
            text_color="#ffffff"
        )
        icon_lbl.place(relx=0.5, rely=0.5, anchor="center")   # Centre the letter in the badge.

        # ── Name label ────────────────────────────────────────────────────────
        name_lbl = ctk.CTkLabel(card, text=h["name"],
                                 font=("Segoe UI", 13, "bold"), text_color=TEXT)
        name_lbl.grid(row=0, column=1, sticky="sw", pady=(12, 0))

        # ── Subtitle (e.g. "45 shares · Equity") ─────────────────────────────
        sub_lbl = ctk.CTkLabel(card, text=h["sub"],
                                font=("Segoe UI", 10), text_color=MUTED)
        sub_lbl.grid(row=1, column=1, sticky="nw", pady=(0, 12))

        # ── Current value (top-right of card) ─────────────────────────────────
        val_lbl = ctk.CTkLabel(card, text=format_inr(h["value"]),
                                font=("Segoe UI", 13, "bold"), text_color=TEXT)
        val_lbl.grid(row=0, column=2, sticky="se", padx=(8, 12), pady=(12, 0))

        # ── Percentage gain/loss (bottom-right of card) ───────────────────────
        sign = "+" if pct >= 0 else ""
        pct_lbl = ctk.CTkLabel(
            card,
            text=sign + str(round(pct, 1)) + "%",
            font=("Segoe UI", 11),
            text_color=get_pct_color(pct)
        )
        pct_lbl.grid(row=1, column=2, sticky="ne", padx=(8, 12), pady=(0, 12))

        # ── Move to next column; wrap to new row every 3 cards ────────────────
        col += 1
        if col == 3:
            col = 0
            row += 1

    # Make all 3 columns share width equally.
    for c in range(3):
        holdings_frame.columnconfigure(c, weight=1)


