                                  fg_color=INPUTBG, border_color=BORDER,
                                  text_color=TEXT, button_color=BORDER,
                                  dropdown_fg_color=CARD)
    combo_type.set("Equity")    # Default selection.
    combo_type.grid(row=1, column=0, sticky="ew", padx=(0, 6))

    ctk.CTkLabel(row2, text="Subtitle", font=("Segoe UI", 10),
                  text_color=MUTED).grid(row=0, column=1, sticky="w")
    entry_sub = ctk.CTkEntry(row2, placeholder_text="45 shares · Equity",
                               fg_color=INPUTBG, border_color=BORDER,
                               text_color=TEXT, placeholder_text_color=MUTED)
    entry_sub.grid(row=1, column=1, sticky="ew", padx=(6, 0))

    # ── Row 3: Invested Amount + Current Value ────────────────────────────────
    row3 = ctk.CTkFrame(form_window, fg_color="transparent")
    row3.pack(fill="x", padx=20, pady=4)
    row3.columnconfigure(0, weight=1)
    row3.columnconfigure(1, weight=1)

    ctk.CTkLabel(row3, text="Invested (₹)", font=("Segoe UI", 10),
                  text_color=MUTED).grid(row=0, column=0, sticky="w")
    entry_invested = ctk.CTkEntry(row3, placeholder_text="100000",
                                   fg_color=INPUTBG, border_color=BORDER,
                                   text_color=TEXT, placeholder_text_color=MUTED)
    entry_invested.grid(row=1, column=0, sticky="ew", padx=(0, 6))

    ctk.CTkLabel(row3, text="Current Value (₹)", font=("Segoe UI", 10),
                  text_color=MUTED).grid(row=0, column=1, sticky="w")
    entry_value = ctk.CTkEntry(row3, placeholder_text="128450",
                                fg_color=INPUTBG, border_color=BORDER,
                                text_color=TEXT, placeholder_text_color=MUTED)
    entry_value.grid(row=1, column=1, sticky="ew", padx=(6, 0))

    # ── Row 4: Icon Colour Picker ─────────────────────────────────────────────
    row4 = ctk.CTkFrame(form_window, fg_color="transparent")
    row4.pack(fill="x", padx=20, pady=4)

    ctk.CTkLabel(row4, text="Icon Color", font=("Segoe UI", 10),
                  text_color=MUTED).pack(anchor="w")

    # Parallel lists: colour names shown to user ↔ actual hex values used in code.
    color_options = ["Blue",    "Orange",  "Teal",    "Purple",  "Red",     "Green",   "Yellow" ]
    color_values  = ["#3b82f6", "#f97316", "#00d4aa", "#a78bfa", "#f43f5e", "#22c55e", "#eab308"]

    combo_color = ctk.CTkComboBox(row4, values=color_options,
                                   fg_color=INPUTBG, border_color=BORDER,
                                   text_color=TEXT, button_color=BORDER,
                                   dropdown_fg_color=CARD)
    combo_color.set("Blue")
    combo_color.pack(fill="x")

    # ── Inner function: do_add — runs when user clicks "Add to Portfolio" ──────
    # This is a "closure" — a function defined inside another function.
    # It can access the entry widgets defined above because Python allows that.
    def do_add():
        # Read and clean up all the form field values.
        name           = entry_name.get().strip()           # .get() reads the typed text.
        ticker         = entry_ticker.get().strip().upper() # .upper() = RELIANCE not reliance.
        asset_type     = combo_type.get()
        sub            = entry_sub.get().strip()
        inv_str        = entry_invested.get().strip()
        val_str        = entry_value.get().strip()
        chosen_color_name = combo_color.get()

        # ── Validation: check that required fields are filled correctly ────────
        if name == "":
            messagebox.showerror("Missing Field", "Please enter an asset name.",
                                  parent=form_window)
            return   # Stop here — don't add anything.

        # .replace(".", "", 1) removes one decimal point before checking all digits.
        # This lets us accept "128450.50" but reject "abc".
        if inv_str == "" or not inv_str.replace(".", "", 1).isdigit():
            messagebox.showerror("Invalid Input", "Please enter a valid invested amount.",
                                  parent=form_window)
            return

        if val_str == "" or not val_str.replace(".", "", 1).isdigit():
            messagebox.showerror("Invalid Input", "Please enter a valid current value.",
                                  parent=form_window)
            return

        # Convert string inputs to float numbers.
        invested = float(inv_str)
        value    = float(val_str)

        # If ticker was left blank, use the first letter of the name as the badge letter.
        if ticker == "":
            ticker = name[0].upper()

        # If subtitle was left blank, fall back to the asset type.
        if sub == "":
            sub = asset_type

        # Find the hex colour that matches the chosen colour name.
        picked_color = "#3b82f6"   # Default: blue.
        for idx, cname in enumerate(color_options):
            if cname == chosen_color_name:
                picked_color = color_values[idx]
                break

        # Build the holding dictionary and add it to our global notebook.
        # datetime.now() stamps the exact moment this investment was added.
        new_holding = {
            "name":     name,
            "ticker":   ticker,
            "type":     asset_type,
            "sub":      sub,
            "invested": invested,
            "value":    value,
            "color":    picked_color,
            "letter":   ticker[0],
            "added_at": datetime.now()   # real timestamp — used by the chart X-axis
        }
        holdings_list.append(new_holding)

        # Snapshot the portfolio total RIGHT NOW and store it in history.
        # The chart only ever plots these real snapshots — no fake interpolated past.
        total_v = sum(h["value"]    for h in holdings_list)
        total_i = sum(h["invested"] for h in holdings_list)
        portfolio_history.append((datetime.now(), total_v, total_i))

        form_window.destroy()        # Close the popup.
        recalculate_and_refresh()    # Refresh all numbers and charts.

    # ── Submit button ──────────────────────────────────────────────────────────
    add_btn = ctk.CTkButton(
        form_window,
        text="Add to Portfolio",
        fg_color=ACCENT,
        text_color=BG,
        font=("Segoe UI", 12, "bold"),
        hover_color="#00b899",   # Slightly darker teal when mouse hovers.
        command=do_add           # Call do_add() when clicked.
    )
    add_btn.pack(fill="x", padx=20, pady=(10, 18))


